{
  "name": "sentinel-auth",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web-demo",
    "dev:mobile": "npm run dev --workspace apps/mobile-demo",
    "build": "npm run build --workspace apps/api",
    "db:migrate": "npm run db:migrate --workspace apps/api",
    "db:seed": "npm run db:seed --workspace apps/api"
  },
  "engines": {
    "node": ">=20"
  }
}
