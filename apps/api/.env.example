NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel_auth
REDIS_URL=redis://localhost:6379
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081,http://localhost:19006
TRUST_PROXY=true

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
